# Telegram Bot Configuration
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
# Optional custom local Bot API server (e.g. http://localhost:8081)
TELEGRAM_API_SERVER=

# Database Configuration
# PostgreSQL format: postgresql+asyncpg://user:password@localhost:5432/dbname
# SQLite fallback format: sqlite+aiosqlite:///bot.db
DATABASE_URL=sqlite+aiosqlite:///bot.db

# Proxy Configuration (Supports HTTP, HTTPS, SOCKS5 - ASOCKS style)
# Example: socks5://username:password@proxy_host:proxy_port
PROXY_URL=

# Scraper & Testing Configuration
# Set MOCK_MODE to True to run local tests with mock video downloads (Big Buck Bunny)
# Set to False for real live scraping of the Gogoanime targets
MOCK_MODE=True
